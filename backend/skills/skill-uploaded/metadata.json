{
  "name": "skill-uploaded",
  "description": "通过 Felo YouTube Subtitling API 获取 YouTube 视频的字幕/字幕文本，支持指定语言和时间戳。",
  "created_at": "2026-03-07T08:00:33.495903Z",
  "author": "anonymous",
  "ui_config": {
    "type": "chat",
    "supports_progress": false,
    "output_types": [
      "text",
      "markdown"
    ]
  },
  "execution": {
    "type": "http",
    "method": "GET",
    "url": "https://openapi.felo.ai/v2/youtube/subtitling",
    "headers": {
      "Authorization": "Bearer {{ENV:FELO_API_KEY}}"
    },
    "query_params": {
      "video_code": "{{video_code}}"
    },
    "param_extractors": {
      "video_code": "youtube_video_id"
    },
    "response": {
      "success_codes": [
        0
      ],
      "format": "youtube_subtitles"
    }
  }
}